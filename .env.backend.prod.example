# Copy to .env.backend.prod and fill in real values.

# Supabase target
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Backend binding
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Backend secrets
AUTOCOMPLETER_BACKEND_ADMIN_SECRET=
AUTOCOMPLETER_SUPABASE_URL=
AUTOCOMPLETER_SUPABASE_SECRET_KEY=
# Optional for future direct client-side Supabase usage; not currently used by the backend:
# AUTOCOMPLETER_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback if you have not migrated yet:
# AUTOCOMPLETER_SUPABASE_SERVICE_ROLE_KEY=

# Upstream inference
AUTOCOMPLETER_PROXY_PRIMARY_BASE_URL=
AUTOCOMPLETER_PROXY_PRIMARY_API_KEY=
AUTOCOMPLETER_PROXY_PRIMARY_DEFAULT_MODEL=

# Optional fallback
AUTOCOMPLETER_PROXY_FALLBACK_BASE_URL=
AUTOCOMPLETER_PROXY_FALLBACK_API_KEY=
AUTOCOMPLETER_PROXY_FALLBACK_DEFAULT_MODEL=

# Public landing page wiring
AUTOCOMPLETER_PUBLIC_ALLOWED_ORIGINS=https://autocompleter.dev,https://autocompleter-259.pages.dev,https://landing-dev.autocompleter-259.pages.dev
AUTOCOMPLETER_PUBLIC_INSTALL_DOCS_URL=https://github.com/henryz2004/autocompleter/blob/main/docs/friend-beta.md
