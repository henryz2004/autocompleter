---
const points = [
  {
    label: "Works across every app",
    body: "macOS-wide. Terminal, Slack, Gmail, VS Code, your writing app. Same overlay, one hotkey.",
  },
  {
    label: "Uses live context",
    body: "Reads the visible window: the thread above your cursor, the file you're in, the command you were halfway through.",
  },
  {
    label: "Built for real work",
    body: "Tuned for commit messages, short replies, and continuations. Not marketing fluff.",
  },
];
---

<section class="proof">
  <div class="container proof-inner">
    <div class="proof-grid">
      {points.map((point) => (
        <article class="proof-card">
          <h3 class="proof-title">{point.label}</h3>
          <p class="proof-body body-muted">{point.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .proof {
    padding: var(--space-10) 0;
    border-top: 1px solid var(--color-border);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .proof-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .proof-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .proof-body {
    font-size: 0.95rem;
    line-height: 1.55;
  }

  @media (max-width: 820px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
