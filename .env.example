# Copy this file to .env and fill in the beta or BYO provider configuration
# you want. The app reads .env from the repository root and falls back to real
# env vars.

# ---------------------------------------------------------------------------
# Friend beta (proxy-first)
# ---------------------------------------------------------------------------
# The hosted beta backend URLs are already filled in below. Most testers only
# need to replace the install key and install id. In proxy mode, generation
# always goes through the hosted backend; local provider/model settings below
# are ignored for request routing.

AUTOCOMPLETER_BETA_MODE=1
AUTOCOMPLETER_PROXY_ENABLED=1
AUTOCOMPLETER_PROXY_BASE_URL=https://autocompleter-beta-backend.onrender.com/v1
AUTOCOMPLETER_PROXY_API_KEY=replace-with-install-key

# Telemetry is opt-out for the beta. Set to 0 if you do not want to send
# product-usage metrics back to the Autocompleter team.
AUTOCOMPLETER_TELEMETRY_ENABLED=1
AUTOCOMPLETER_TELEMETRY_URL=https://autocompleter-beta-backend.onrender.com/v1/telemetry/events
# Optional override. If unset, telemetry reuses AUTOCOMPLETER_PROXY_API_KEY.
# AUTOCOMPLETER_TELEMETRY_API_KEY=

# Recommended for the beta backend: use the install id returned by
# /admin/install-keys so telemetry and proxy usage line up cleanly.
AUTOCOMPLETER_INSTALL_ID=replace-with-install-id

# Optional BYO provider settings
# These only apply when AUTOCOMPLETER_PROXY_ENABLED=0.
AUTOCOMPLETER_LLM_PROVIDER=openai
AUTOCOMPLETER_LLM_BASE_URL=https://api.groq.com/openai/v1
AUTOCOMPLETER_LLM_MODEL=qwen/qwen3-32b

# Optional BYO fallback used when the primary does not respond quickly enough
AUTOCOMPLETER_FALLBACK_PROVIDER=openai
AUTOCOMPLETER_FALLBACK_BASE_URL=https://api.cerebras.ai/v1
AUTOCOMPLETER_FALLBACK_MODEL=qwen-3-235b-a22b-instruct-2507
AUTOCOMPLETER_ESCALATION_TIMEOUT_MS=400

# Hotkeys
AUTOCOMPLETER_HOTKEY=ctrl+space
AUTOCOMPLETER_REGENERATE_HOTKEY=ctrl+r

# Features
AUTOCOMPLETER_AUTO_TRIGGER=0
AUTOCOMPLETER_FOLLOWUP_AFTER_ACCEPT=1
AUTOCOMPLETER_MEMORY=0
AUTOCOMPLETER_MEMORY_LLM_PROVIDER=groq
AUTOCOMPLETER_MEMORY_LLM_MODEL=qwen/qwen3-32b
AUTOCOMPLETER_MEMORY_EMBEDDER_PROVIDER=openai
AUTOCOMPLETER_MEMORY_EMBEDDER_MODEL=text-embedding-3-small
AUTOCOMPLETER_MEMORY_DECAY_RATE=0.01

# Provider credentials
# Set only the keys needed for the providers you use. For the friend beta,
# you can usually leave these blank and use the proxy config above. To use
# your own provider instead, set AUTOCOMPLETER_PROXY_ENABLED=0.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
SAMBANOVA_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=
