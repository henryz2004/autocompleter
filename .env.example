# Copy this file to .env and fill in the provider configuration you want.
# The app reads .env from the repository root and falls back to real env vars.

# Primary model provider
AUTOCOMPLETER_LLM_PROVIDER=openai
AUTOCOMPLETER_LLM_BASE_URL=https://api.cerebras.ai/v1
AUTOCOMPLETER_LLM_MODEL=qwen-3-235b-a22b-instruct-2507

# Fallback provider used when the primary does not respond quickly enough
AUTOCOMPLETER_FALLBACK_PROVIDER=openai
AUTOCOMPLETER_FALLBACK_BASE_URL=https://api.groq.com/openai/v1
AUTOCOMPLETER_FALLBACK_MODEL=qwen/qwen3-32b
AUTOCOMPLETER_ESCALATION_TIMEOUT_MS=400

# Hotkeys
AUTOCOMPLETER_HOTKEY=ctrl+space
AUTOCOMPLETER_REGENERATE_HOTKEY=ctrl+r

# Features
AUTOCOMPLETER_AUTO_TRIGGER=0
AUTOCOMPLETER_FOLLOWUP_AFTER_ACCEPT=1
AUTOCOMPLETER_MEMORY=0
AUTOCOMPLETER_MEMORY_LLM_PROVIDER=groq
AUTOCOMPLETER_MEMORY_LLM_MODEL=qwen/qwen3-32b
AUTOCOMPLETER_MEMORY_EMBEDDER_PROVIDER=openai
AUTOCOMPLETER_MEMORY_EMBEDDER_MODEL=text-embedding-3-small
AUTOCOMPLETER_MEMORY_DECAY_RATE=0.01

# Provider credentials
# Set only the keys needed for the providers you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
SAMBANOVA_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=

